{
	"name": "supastarter-nextjs",
	"private": true,
	"scripts": {
		"build": "dotenv -c -- turbo build",
		"dev": "dotenv -c -- turbo dev --concurrency 15",
		"type-check": "dotenv -c -- turbo type-check",
		"start": "dotenv -c -- turbo start",
		"lint": "biome lint . ",
		"check": "biome check",
		"clean": "turbo clean",
		"format": "biome format . --write"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.14.0",
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@repo/tsconfig": "workspace:*",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^24.10.1",
		"dotenv-cli": "^11.0.0",
		"tsx": "^4.20.6",
		"turbo": "^2.6.1",
		"typescript": "5.9.3"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "19.2.2",
			"@types/react-dom": "19.2.2"
		},
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"@swc/core",
			"prisma",
			"prisma-zod-generator",
			"sharp"
		]
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.99.0",
		"@supabase/supabase-js": "^2.106.2",
		"bcryptjs": "^3.0.3",
		"clsx": "^2.1.1",
		"next": "^16.2.6",
		"openai": "^6.39.0",
		"tailwind-merge": "^3.6.0"
	}
}
